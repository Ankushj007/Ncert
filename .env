# ============================================================
#   VidyaSetu – Backend Environment Variables
#   DO NOT commit this file to GitHub / any public repo
# ============================================================

# ── Anthropic Claude API ──────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_CLAUDE_API_KEY_HERE

# ── OpenAI (Embeddings for RAG / Vector Search) ───────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-PASTE_YOUR_OPENAI_KEY_HERE

# ── Pinecone (Vector Database for NCERT content search) ───
# Sign up free at: https://app.pinecone.io/
PINECONE_API_KEY=PASTE_YOUR_PINECONE_API_KEY_HERE
PINECONE_INDEX_NAME=vidyasetu-ncert
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Firebase (User Auth, Bookmarks, Progress) ─────────────
# Create project at: https://console.firebase.google.com/
FIREBASE_API_KEY=PASTE_YOUR_FIREBASE_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Google Cloud (Text-to-Speech / Translation optional) ──
# Enable at: https://console.cloud.google.com/
GOOGLE_API_KEY=PASTE_YOUR_GOOGLE_API_KEY_HERE

# ── Server Config ─────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────
# Max AI requests per user per hour
RATE_LIMIT_PER_HOUR=30
